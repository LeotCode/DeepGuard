# ──────────────────────────────────────────────────────────────────
# DeepGuard Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to source control.
# ──────────────────────────────────────────────────────────────────

# ── Firebase Admin SDK ────────────────────────────────────────────
# Option A: point to the service-account JSON file
FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-service-account.json

# Option B: paste the JSON content directly (useful for cloud deploys)
# FIREBASE_SERVICE_ACCOUNT_INLINE={"type":"service_account","project_id":"..."}

# ── Model weight paths (optional — defaults shown) ────────────────
# EFFICIENTNET_IMAGE_MODEL_PATH=models/efficientnet_image.pth
# XCEPTION_MODEL_PATH=models/xception_model.h5
# RESNET_MODEL_PATH=models/resnet_model.keras
# EFFICIENTNET_VIDEO_MODEL_PATH=models/efficientnet_video.pth

# ── Server ────────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8000
